# main.tf - generated by the Terraform Generator agent
terraform {
  required_version = ">= 1.9"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.60"
    }
  }
}

provider "aws" {
  region = "us-east-1"
}

resource "aws_vpc" "staging-vpc" {
  cidr_block           = "10.20.0.0/16"
  enable_dns_hostnames = true
  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

resource "aws_subnet" "staging-subnet-a" {
  vpc_id            = aws_vpc.staging-vpc.id
  cidr_block        = "10.20.1.0/24"
  availability_zone = "us-east-1a"
  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

resource "aws_security_group" "staging-web-sg" {
  name   = "staging-web-sg"
  vpc_id = aws_vpc.staging-vpc.id

  ingress {
    from_port   = 443
    to_port     = 443
    protocol    = "tcp"
    cidr_blocks = ["0.0.0.0/0"]
  }

  ingress {
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_blocks = ["10.20.0.0/16"]
  }

  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

resource "aws_instance" "staging-web-1" {
  ami                    = "ami-0abcd1234efgh5678"
  instance_type          = "t3.medium"
  subnet_id              = aws_subnet.staging-subnet-a.id
  vpc_security_group_ids = [
    aws_security_group.staging-web-sg.id
  ]
  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

resource "aws_instance" "staging-web-2" {
  ami                    = "ami-0abcd1234efgh5678"
  instance_type          = "t3.medium"
  subnet_id              = aws_subnet.staging-subnet-a.id
  vpc_security_group_ids = [
    aws_security_group.staging-web-sg.id
  ]
  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

resource "aws_db_instance" "staging-db" {
  engine              = "postgres"
  engine_version      = "16.4"
  instance_class      = "db.t3.medium"
  allocated_storage   = 50
  storage_encrypted   = true
  skip_final_snapshot = true
  db_name             = "staging"
  username            = "app_admin"
  password            = var.db_password
  tags = {
    environment = "staging"
    owner       = "platform-team"
    cost-center = "eng-infra"
  }
}

variable "db_password" {
  type      = string
  sensitive = true
}
