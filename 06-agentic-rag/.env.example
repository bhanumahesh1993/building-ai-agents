# .env.example
DATABASE_URL=postgresql://localhost/kb
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...
ANALYZE_MODEL=claude-haiku-4-5
SYNTH_MODEL=claude-sonnet-4-5
CHECK_MODEL=claude-haiku-4-5
RERANK_MODEL=rerank-v3.5
MAX_LOOPS=2
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <token>
# Only needed after the Qdrant migration:
QDRANT_URL=
QDRANT_API_KEY=
